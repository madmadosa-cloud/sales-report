# Django settings (copy this file to .env and adjust)
# Generate a secret key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: PDF Korean font path (Windows example)
# REPORT_FONT_PATH=C:\Windows\Fonts\malgun.ttf
